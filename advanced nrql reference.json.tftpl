    {
      "guid": "NDEyMDgzN3xWSVp8REFTSEJPQVJEfDQ3MDIwMTk0",
      "name": "Metrics",
      "description": null,
      "widgets": [
        {
          "id": "523087739",
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "## Topics\n* [Querying metric data](https://docs.newrelic.com/docs/telemetry-data-platform/get-data/apis/query-metric-data-type/)\n* [Metric wildcards](https://docs.newrelic.com/docs/telemetry-data-platform/get-data/apis/query-metric-data-type/#query-multiple-metrics-wildcards)\n* [Querying timeslice data](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/nrql-query-tutorials/query-apm-metric-timeslice-data-nrql/)"
          }
        },
        {
          "id": "523087740",
          "title": "Metric AWS",
          "layout": {
            "column": 3,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "linear"
            },
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "markers": {
              "displayedTypes": {
                "criticalViolations": false,
                "deployments": true,
                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "SELECT average(`aws.ec2.CPUUtilization`) FROM Metric FACET entityName SINCE  24 hours ago TIMESERIES  MAX "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": {
              "isLabelVisible": true
            },
            "yAxisLeft": {
              "zero": true
            },
            "yAxisRight": {
              "zero": true
            }
          }
        },
        {
          "id": "523087741",
          "title": "What metrics are available?",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "FROM Metric SELECT uniques(metricName)"
              }
            ]
          }
        },
        {
          "id": "523087742",
          "title": "What attributes are available for my metric?",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.json"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT keyset() from Metric where metricName='aws.ec2.CPUUtilization'"
              }
            ]
          }
        },
        {
          "id": "523087743",
          "title": " Timeslice",
          "layout": {
            "column": 5,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "SELECT apdex(newrelic.timeslice.value) FROM Metric WHERE appName='${apm_appname}' AND newrelic.timeslice.value IS NOT NULL and metricTimesliceName like 'EndUser/Apdex/Browser/Linux/%' WITH METRIC_FORMAT 'EndUser/Apdex/Browser/Linux/{flavour}/%'  facet flavour "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        }
      ]
    },
