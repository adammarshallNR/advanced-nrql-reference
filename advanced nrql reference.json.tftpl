    {
      "guid": "NDEyMDgzN3xWSVp8REFTSEJPQVJEfDQ3MDIwMTkx",
      "name": "Faceting",
      "description": null,
      "widgets": [
        {
          "id": "523087713",
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 1,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "## Topics:\n* [Multiple facets](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-syntax-clauses-functions/#sel-facet)\n* [Facet cases](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-syntax-clauses-functions/#sel-facet-cases)\n* [Facet buckets](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-syntax-clauses-functions/#func-buckets)\n* [Facet by time](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/nrql-query-tutorials/nrql-group-results-across-time/)"
          }
        },
        {
          "id": "523087714",
          "title": "",
          "layout": {
            "column": 2,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT average(backendDuration) from PageView where city is not null facet city"
              }
            ],
            "thresholds": []
          }
        },
        {
          "id": "523087715",
          "title": "Group data by attribute using FACET",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT average(backendDuration) from PageView where city is not null facet name\n"
              }
            ]
          }
        },
        {
          "id": "523087716",
          "title": "Group by multiple facets",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT average(backendDuration) from PageView where city is not null facet name, countryCode, city limit max\n"
              }
            ]
          }
        },
        {
          "id": "523087717",
          "title": "Facet by  fixed bucket sizes using BUCKETS",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from PageView facet buckets(duration,15,10)\n"
              }
            ]
          }
        },
        {
          "id": "523087718",
          "title": "Facet by custom cases",
          "layout": {
            "column": 3,
            "row": 4,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from PageView  facet cases(where backendDuration < 0.5 as '<0.5', where backendDuration < 1 as '0.5-1', where backendDuration < 5 as '1-5', where backendDuration >= 5 as '>5')\n"
              }
            ]
          }
        },
        {
          "id": "523087719",
          "title": "Facet custom non-numeric cases",
          "layout": {
            "column": 5,
            "row": 4,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from PageView where appName='${browser_appname}'  facet cases(where browserTransactionName like '%/product/*' as 'Product', where browserTransactionName like '%/cart*' as 'Cart', where browserTransactionName like '%' as 'everythingElse')\n"
              }
            ]
          }
        },
        {
          "id": "523087720",
          "title": "Facet by time hourOf()",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) FROM PageView SINCE 7 day ago FACET hourOf(timestamp)\n"
              }
            ]
          }
        },
        {
          "id": "523087721",
          "title": "Histogram()",
          "layout": {
            "column": 10,
            "row": 4,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.histogram"
          },
          "rawConfiguration": {
            "chartStyles": {
              "gradient": {
                "enabled": false
              }
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "SELECT histogram(duration,15,10) from PageView \n"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": {
              "isLabelVisible": true
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        }
      ]
    },
    {
      "guid": "NDEyMDgzN3xWSVp8REFTSEJPQVJEfDQ3MDIwMTky",
      "name": "Timeseries",
      "description": null,
      "widgets": [
        {
          "id": "523087722",
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 1,
            "height": 6
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "## Topics\n* [Bucket size](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-syntax-clauses-functions/#sel-timeseries)\n* Threshold lines\n* Multiple series\n* [Rate()](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-syntax-clauses-functions/#func-rate)\n* [Sliding windows](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/nrql-query-tutorials/create-smoother-charts-sliding-windows/)\n* [Clamping](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/get-started/nrql-math-using-select/#clamp_max-clamp_min)"
          }
        },
        {
          "id": "523087723",
          "title": "",
          "layout": {
            "column": 2,
            "row": 1,
            "width": 9,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Bucket Size\nAs you adjust the time window the bucket size is automaticlly re-calculated to work with the amoutn of data being displayed. Fixed bucket sizes will be ignored when there would be more than 366 buckets. Use MAX in order to always have as many buckets and highest fidelity detail as possible."
          }
        },
        {
          "id": "523087724",
          "title": "Threshold lines",
          "layout": {
            "column": 11,
            "row": 1,
            "width": 2,
            "height": 5
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*), 50000 as 'high', 20000 as 'low' from Transaction where appName='${apm_appname}' since 6 hour ago timeseries\n"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087725",
          "title": "Reference chart",
          "layout": {
            "column": 2,
            "row": 3,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from Transaction where appName='${apm_appname}' since 6 hour ago timeseries\n"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087726",
          "title": "Fixed bucket size",
          "layout": {
            "column": 5,
            "row": 3,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from Transaction where appName='${apm_appname}' since 6 hour ago timeseries 10 minutes"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087727",
          "title": "MAX Bucket size",
          "layout": {
            "column": 8,
            "row": 3,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from Transaction where appName = '${apm_appname}' since  24 hours ago TIMESERIES MAX "
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087728",
          "title": "",
          "layout": {
            "column": 2,
            "row": 6,
            "width": 6,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Rate() function explained\n\nCompare the below charts. As you change the time window (using the time picker) the Y axis on the left chart changes to accommodate the bucket size. The chart on the right using rate() remains a consistent y axis."
          }
        },
        {
          "id": "523087729",
          "title": "",
          "layout": {
            "column": 8,
            "row": 6,
            "width": 5,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Slideby() for smoothing charts\nFor spiky charts or calculating the moving average use the slideby() function"
          }
        },
        {
          "id": "523087730",
          "title": "Compare with ",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 1,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) as '${apm_appname}' from Transaction where appName='${apm_appname}' since 6 hour ago timeseries max COMPARE WITH  6 hours ago"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087731",
          "title": "Count of transactions without using rate",
          "layout": {
            "column": 2,
            "row": 8,
            "width": 3,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT count(*) from Transaction where appName='${apm_appname}' since 6 hour ago timeseries 1 minute\n"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087732",
          "title": "Rate Function ",
          "layout": {
            "column": 5,
            "row": 8,
            "width": 3,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT rate(count(*), 1 minute) as 'RPM' from Transaction where appName='${apm_appname}' since 6 hours ago timeseries 1 minute\n"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "id": "523087733",
          "title": "Slideby moving average",
          "layout": {
            "column": 8,
            "row": 8,
            "width": 5,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": "${account_id}",
                "query": "SELECT rate(count(*), 1 minute) as '30 secs' from Transaction where appName='${apm_appname}' since 2 hour ago timeseries 30 seconds\n"
              },
              {
                "accountId": "${account_id}",
                "query": "SELECT rate(count(*), 1 minute) as '5 mins' from Transaction where appName='${apm_appname}' since 2 hour ago timeseries 5 minutes\n"
              },
              {
                "accountId": "${account_id}",
                "query": "SELECT rate(count(*), 1 minute) as 'slideby' from Transaction where appName='${apm_appname}' since 2 hour ago timeseries 5 minutes slide by 30 seconds\n"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        }
      ]
    },
    {
      "guid": "NDEyMDgzN3xWSVp8REFTSEJPQVJEfDQ3MDIwMTkz",
      "name": "Nested Aggregation",
      "description": null,
      "widgets": [
        {
          "id": "523087734",
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 2,
            "height": 6
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "## Topics:\n* What problem does nested aggregation solve?\n* [Nested aggregation Docs](https://docs.newrelic.com/docs/query-your-data/nrql-new-relic-query-language/nrql-query-tutorials/nested-aggregation-make-ordered-computations-single-query/)"
          }
        },
        {
          "id": "523087735",
          "title": "",
          "layout": {
            "column": 3,
            "row": 1,
            "width": 8,
            "height": 1
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "Use nested aggregation to further aggregate data returned from NRDB. For instance in this example we can list servers by average CPU. But to answer the question \"How many servers have an average CPU above 60%\" we need nested aggregation."
          }
        },
        {
          "id": "523087736",
          "title": "Average CPU ",
          "layout": {
            "column": 3,
            "row": 2,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "select average(cpuPercent) as 'avgCpu' from SystemSample facet host.id limit 100\n"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "523087737",
          "title": "How many servers are running hot?",
          "layout": {
            "column": 7,
            "row": 2,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "linear"
            },
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "select count(*) as 'HotCPU' from (select average(cpuPercent) as 'avgCpu' from SystemSample facet host.id limit max) where avgCpu > 20\n"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "523087738",
          "title": "Max RPM (and by App)",
          "layout": {
            "column": 3,
            "row": 5,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "linear"
            },
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "markers": {
              "displayedTypes": {
                "criticalViolations": false,
                "deployments": true,
                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "select rate(count(*),1 minute) as 'rpm' from Transaction facet appName timeseries 5 minutes since 24 hours ago\n"
              },
              {
                "accountIds": [
                  "${account_id}"
                ],
                "query": "select max(rpm) from (select rate(count(*),1 minute) as 'rpm' from Transaction facet appName timeseries 5 minutes) since 24 hours ago timeseries"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": {
              "isLabelVisible": true
            },
            "yAxisLeft": {
              "zero": true
            },
            "yAxisRight": {
              "zero": true
            }
          }
        }
      ]
